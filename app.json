{
  "expo": {
    "name": "Hannas Connect",
    "slug": "hannasconnect",
    "version": "2.0.0",
    "runtimeVersion": "2.0.0",
    "orientation": "portrait",
    "scheme": "hannasconnect",
    "icon": "./assets/images/logoh.jpg",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logoh.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hannas.connect",
      "buildNumber": "9",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera for video calls",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone for calls",
        "UIBackgroundModes": [
          "voip"
        ]
      }
    },
    "android": {
      "package": "com.hannas.connect",
      "versionCode": 97,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logoh.jpg",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.WAKE_LOCK"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "hannasconnect"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "hannasconnect",
              "host": "reset-password"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "hannasconnect",
              "host": "payment"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/logoh.jpg",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera for video calls",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for calls",
          "recordAudioAndroid": true
        }
      ]
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/481dbad8-c70c-4aae-898a-e9964f19fa26"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "callbackUrl": "https://dbvsexpcrojtnriqfbwa.supabase.co/functions/v1/paystack-callback",
      "eas": {
        "projectId": "4bf6247a-fa80-4a8d-b521-b180a4bfd2bc"
      }
    },
    "owner": "offsetdeveloper"
  }
}
